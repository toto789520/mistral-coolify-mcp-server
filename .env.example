# Configuration Coolify API
COOLIFY_URL=https://coolify.example.com
COOLIFY_API_TOKEN=your_coolify_api_token_here

# Configuration du serveur MCP
MCP_SERVER_PORT=3000
MCP_SERVER_HOST=0.0.0.0

# Optionnel: Clé secrète pour l'authentification (si vous voulez ajouter une couche supplémentaire)
AUTH_SECRET=your_optional_auth_secret